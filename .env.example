# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: JWT signing secret (any long random string, min 32 chars)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Required: OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: SerpAPI key for web search (leave blank to disable)
SERP_API_KEY=

# Optional: Telegram bot integration (set TELEGRAM_ENABLED=true to activate)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=
