# SkillBot Environment Configuration
# Copy this file to .env and fill in your values

# JWT Secret (generate a strong random string, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this

# LLM Provider API Keys (set the one(s) you want to use)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: SerpAPI for web search
SERP_API_KEY=your-serpapi-key-here

# Optional: Telegram Bot Integration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhook/telegram

# Database (default works for Docker, change for custom path)
DATABASE_PATH=/app/data/skillbot.db

# Runtime environment
ASPNETCORE_ENVIRONMENT=Production
