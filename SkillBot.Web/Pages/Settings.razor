@page "/settings"

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" />
                <MudText Typo="Typo.h4">Settings</MudText>
            </MudStack>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6">
                <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Tune">
                    <GeneralSettings />
                </MudTabPanel>
                <MudTabPanel Text="Appearance" Icon="@Icons.Material.Filled.Palette">
                    <AppearanceSettings />
                </MudTabPanel>
                <MudTabPanel Text="Privacy" Icon="@Icons.Material.Filled.Lock">
                    <PrivacySettings />
                </MudTabPanel>
                <MudTabPanel Text="About" Icon="@Icons.Material.Filled.Info">
                    <AboutSettings />
                </MudTabPanel>
            </MudTabs>
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

