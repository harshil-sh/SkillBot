@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject CustomAuthStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<a href="#main-content" class="skip-to-content">Skip to main content</a>

<MudThemeProvider Theme="@_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">SkillBot</MudText>
        <MudSpacer />
        <MudTooltip Text="Keyboard shortcuts &amp; help">
            <MudIconButton Icon="@Icons.Material.Filled.Help"
                           Color="Color.Inherit"
                           OnClick="@OpenHelpDialogAsync" />
        </MudTooltip>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode" />
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                    <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">Profile</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Settings" Href="/settings">Settings</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.AdminPanelSettings" Href="/admin">Admin</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@LogoutAsync">Logout</MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Color="Color.Inherit">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">🤖 SkillBot</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent id="main-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<KeyboardShortcutsHandler OnFocusSearch="@HandleFocusSearch"
                           OnNewConversation="@HandleNewConversation"
                           OnCloseDialogs="@HandleCloseDialogs" />

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6366f1",
            Secondary = "#8b5cf6",
            Success = "#10b981",
            Warning = "#f59e0b",
            Error = "#ef4444"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#6366f1",
            Secondary = "#8b5cf6",
            Success = "#10b981",
            Warning = "#f59e0b",
            Error = "#ef4444",
            Background = "#1f2937",
            Surface = "#374151"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    private async Task OpenHelpDialogAsync()
    {
        await DialogService.ShowAsync<HelpDialog>("Help");
    }

    private void HandleFocusSearch() { /* Wire to search input if available */ }
    private void HandleNewConversation() => Navigation.NavigateTo("/chat");
    private void HandleCloseDialogs() { /* Dialogs close themselves on Escape */ }

    private async Task LogoutAsync()
    {
        await AuthStateProvider.MarkUserAsLoggedOutAsync();
        Snackbar.Add("Logged out successfully", Severity.Success);
        Navigation.NavigateTo("/login");
    }
}
