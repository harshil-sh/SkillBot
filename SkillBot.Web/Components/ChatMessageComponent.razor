@inject IJSRuntime JSRuntime

<div class="chat-message-wrapper @(IsUser ? "user-message" : "ai-message")"
     @onmouseover="() => _showActions = true"
     @onmouseout="() => _showActions = false">

    @if (!IsUser)
    {
        <MudAvatar Size="Size.Small" Color="Color.Secondary" Class="message-avatar">AI</MudAvatar>
    }

    <div class="message-bubble @(IsUser ? "user-bubble" : "ai-bubble")">
        @if (IsLoading)
        {
            <div class="loading-dots">
                <span></span><span></span><span></span>
            </div>
        }
        else if (IsUser)
        {
            <MudText>@Content</MudText>
        }
        else
        {
            <MarkdownRenderer Content="@Content" />
        }

        <div class="message-meta">
            <MudText Typo="Typo.caption" Class="timestamp-text">@Timestamp.ToLocalTime().ToString("HH:mm")</MudText>

            @if (!IsUser && _showActions && !IsLoading)
            {
                <div class="message-actions">
                    <MudTooltip Text="@(_copied ? "Copied!" : "Copy")">
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                       Size="Size.Small"
                                       OnClick="CopyToClipboardAsync" />
                    </MudTooltip>
                    @if (OnRegenerate.HasDelegate)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Small"
                                       OnClick="() => OnRegenerate.InvokeAsync()" />
                    }
                </div>
            }
        </div>
    </div>

    @if (IsUser)
    {
        <MudAvatar Size="Size.Small" Color="Color.Primary" Class="message-avatar">ME</MudAvatar>
    }
</div>

@code {
    [Parameter] public string? Content { get; set; }
    [Parameter] public bool IsUser { get; set; }
    [Parameter] public DateTime Timestamp { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback OnRegenerate { get; set; }

    private bool _showActions;
    private bool _copied;

    private async Task CopyToClipboardAsync()
    {
        if (!string.IsNullOrEmpty(Content))
        {
            await JSRuntime.InvokeVoidAsync("skillbotInterop.copyToClipboard", Content);
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
    }
}

<style>
    .chat-message-wrapper {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        margin-bottom: 12px;
    }

    .user-message {
        flex-direction: row-reverse;
    }

    .ai-message {
        flex-direction: row;
    }

    .message-avatar {
        flex-shrink: 0;
    }

    .message-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 16px;
        position: relative;
    }

    .user-bubble {
        background-color: var(--mud-palette-primary);
        color: var(--mud-palette-primary-text);
        border-bottom-right-radius: 4px;
    }

    .ai-bubble {
        background-color: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-bottom-left-radius: 4px;
    }

    .message-meta {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 4px;
        margin-top: 4px;
    }

    .timestamp-text {
        opacity: 0.6;
        font-size: 0.7rem;
    }

    .message-actions {
        display: flex;
        gap: 2px;
    }

    .loading-dots {
        display: flex;
        gap: 4px;
        align-items: center;
        padding: 4px 0;
    }

    .loading-dots span {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: var(--mud-palette-text-secondary);
        animation: typing-bounce 1.4s infinite ease-in-out both;
    }

    .loading-dots span:nth-child(1) { animation-delay: -0.32s; }
    .loading-dots span:nth-child(2) { animation-delay: -0.16s; }

    @@keyframes typing-bounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1); }
    }
</style>
