@inject IJSRuntime JSRuntime
@inject ISkillBotApiClient ApiClient

<div class="conversation-list">
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               FullWidth="true"
               Class="mb-3"
               OnClick="@NewChat">
        New Chat
    </MudButton>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        @foreach (var conv in _conversations)
        {
            <div class="conversation-item @(conv.Id == CurrentConversationId ? "active" : "")"
                 @onclick="() => SelectConversation(conv.Id)">
                <div class="conversation-content">
                    <MudText Typo="Typo.body2" Class="conversation-title">@conv.Title</MudText>
                    <MudText Typo="Typo.caption" Class="conversation-preview">@conv.LastMessage</MudText>
                    <MudText Typo="Typo.caption" Class="conversation-time">
                        @conv.Timestamp.ToLocalTime().ToString("MMM d")
                    </MudText>
                </div>
                <div class="conversation-item-actions" @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => DeleteConversationAsync(conv.Id))" />
                </div>
            </div>
        }

        @if (!_conversations.Any())
        {
            <MudText Typo="Typo.body2" Class="pa-3" Color="Color.Secondary">No conversations yet</MudText>
        }
    }
</div>

@code {
    [Parameter] public EventCallback<string> OnConversationSelected { get; set; }
    [Parameter] public EventCallback OnNewChat { get; set; }
    [Parameter] public string CurrentConversationId { get; set; } = string.Empty;

    private List<SkillBot.Web.Services.Models.ConversationSummary> _conversations = new();
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadConversationsAsync();
    }

    private async Task LoadConversationsAsync()
    {
        _isLoading = true;
        try
        {
            _conversations = await ApiClient.GetConversationsAsync();
        }
        catch { /* ignore */ }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectConversation(string id)
    {
        await OnConversationSelected.InvokeAsync(id);
    }

    private async Task NewChat()
    {
        await OnNewChat.InvokeAsync();
    }

    private async Task DeleteConversationAsync(string id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this conversation?");
        if (confirmed)
        {
            try
            {
                await ApiClient.DeleteConversationAsync(id);
                _conversations.RemoveAll(c => c.Id == id);
            }
            catch { /* ignore */ }
        }
    }

    public async Task RefreshAsync() => await LoadConversationsAsync();
}

<style>
    .conversation-list {
        padding: 8px;
    }

    .conversation-item {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 8px;
        cursor: pointer;
        margin-bottom: 4px;
        transition: background-color 0.2s;
    }

    .conversation-item:hover {
        background-color: var(--mud-palette-action-hover);
    }

    .conversation-item.active {
        background-color: var(--mud-palette-primary-hover);
    }

    .conversation-content {
        flex: 1;
        overflow: hidden;
    }

    .conversation-title {
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .conversation-preview {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        opacity: 0.7;
    }

    .conversation-time {
        opacity: 0.5;
    }
</style>
