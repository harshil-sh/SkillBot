@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudStack Spacing="4">
    <MudText Typo="Typo.h6">Privacy Preferences</MudText>

    <MudCard Elevation="1">
        <MudCardContent>
            <MudStack Spacing="2">
                <MudSwitch @bind-Value="_saveHistory"
                           Label="Save conversation history"
                           Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-9">
                    Store your chat sessions in the database for future access.
                </MudText>

                <MudDivider Light="true" Class="my-2" />

                <MudSwitch @bind-Value="_analytics"
                           Label="Analytics opt-in"
                           Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-9">
                    Help improve SkillBot by sharing anonymous usage analytics.
                </MudText>

                <MudDivider Light="true" Class="my-2" />

                <MudSwitch @bind-Value="_shareUsage"
                           Label="Share usage data"
                           Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-9">
                    Share aggregate usage data to improve AI model performance.
                </MudText>
            </MudStack>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SavePrivacyAsync"
                       Disabled="@_saving"
                       StartIcon="@Icons.Material.Filled.Save">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save Privacy Settings
            </MudButton>
        </MudCardActions>
    </MudCard>

    <MudDivider />

    @* Danger Zone *@
    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-error); border-radius: 8px;" Class="pa-4">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
                <MudText Typo="Typo.h6" Color="Color.Error">Danger Zone</MudText>
            </MudStack>

            <MudText Typo="Typo.body2" Color="Color.Secondary">
                These actions are irreversible. Please proceed with caution.
            </MudText>

            <MudDivider Light="true" />

            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap">
                    <div>
                        <MudText Typo="Typo.subtitle2">Delete All Conversations</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Permanently remove all your chat history.</MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                               OnClick="ConfirmDeleteConversationsAsync"
                               StartIcon="@Icons.Material.Filled.DeleteSweep">
                        Delete All Conversations
                    </MudButton>
                </MudStack>

                <MudDivider Light="true" />

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap">
                    <div>
                        <MudText Typo="Typo.subtitle2">Export Data</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Download a copy of all your data.</MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               OnClick="@(() => Snackbar.Add("Data export is not yet implemented.", Severity.Info))"
                               StartIcon="@Icons.Material.Filled.Download">
                        Export Data
                    </MudButton>
                </MudStack>

                <MudDivider Light="true" />

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap">
                    <div>
                        <MudText Typo="Typo.subtitle2">Delete Account</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Permanently delete your account and all associated data.</MudText>
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                               OnClick="ConfirmDeleteAccountAsync"
                               StartIcon="@Icons.Material.Filled.PersonRemove">
                        Delete Account
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private bool _saveHistory = true;
    private bool _analytics = false;
    private bool _shareUsage = false;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _saveHistory = await LocalStorage.GetItemAsync<bool?>("priv_saveHistory") ?? true;
        _analytics = await LocalStorage.GetItemAsync<bool?>("priv_analytics") ?? false;
        _shareUsage = await LocalStorage.GetItemAsync<bool?>("priv_shareUsage") ?? false;
    }

    private async Task SavePrivacyAsync()
    {
        _saving = true;
        try
        {
            await LocalStorage.SetItemAsync("priv_saveHistory", _saveHistory);
            await LocalStorage.SetItemAsync("priv_analytics", _analytics);
            await LocalStorage.SetItemAsync("priv_shareUsage", _shareUsage);
            Snackbar.Add("Privacy settings saved", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private async Task ConfirmDeleteConversationsAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete All Conversations",
            "Are you sure you want to permanently delete all your conversations? This cannot be undone.",
            yesText: "Delete All",
            cancelText: "Cancel");

        if (confirmed == true)
            Snackbar.Add("Delete all conversations is not yet implemented.", Severity.Info);
    }

    private async Task ConfirmDeleteAccountAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Account",
            "This will permanently delete your account and ALL associated data. This action cannot be undone. Are you absolutely sure?",
            yesText: "Yes, Delete My Account",
            cancelText: "Cancel");

        if (confirmed == true)
            Snackbar.Add("Account deletion is not yet implemented.", Severity.Info);
    }
}
